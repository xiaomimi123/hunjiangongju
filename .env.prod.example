# ===== 生产环境配置（复制为 .env.prod 后填写）=====
# 提示：可直接运行 deploy/deploy.sh，它会交互式帮你生成本文件并自动填入随机密钥。

# 访问域名（必须已把 DNS A 记录解析到本服务器公网 IP）
DOMAIN=example.com
# 申请 HTTPS 证书用的邮箱（Let's Encrypt 到期提醒）
ACME_EMAIL=admin@example.com

# 初始管理员账号（首次部署自动创建；请使用强密码）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-strong-password
ADMIN_NICKNAME=管理员

# 数据库（POSTGRES_PASSWORD 与 DATABASE_URL 中的密码必须一致）
POSTGRES_USER=mixcut
POSTGRES_PASSWORD=change-this-db-password
POSTGRES_DB=mixcut
DATABASE_URL=postgresql://mixcut:change-this-db-password@postgres:5432/mixcut

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT 会话签名密钥（随机长字符串，务必修改）
JWT_SECRET=change-this-to-a-long-random-secret

# 素材/成片存储目录（容器内路径，勿改）
DATA_DIR=/data

# 是否顺带写入演示数据（演示学员/素材/文案）。生产留空或 0；仅需体验时设为 1
SEED_DEMO=
