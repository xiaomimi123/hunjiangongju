DATABASE_URL=postgresql://mixcut:mixcut@postgres:5432/mixcut
REDIS_HOST=redis
REDIS_PORT=6379
JWT_SECRET=dev-secret-change-me
DATA_DIR=/data
# 用于给 /api/files 的签名 URL 做 HMAC 签名/校验（供阿里云百炼 DashScope 等外部服务拉取音频/帧）
ASSET_URL_SECRET=dev-asset-secret-change-me
# 本机可访问的公网 base URL，用于拼接签名 URL。本地 localhost 不可被 DashScope 访问，
# 本地开发走 mock；真实校验需部署到有公网地址的服务器后再验证。
PUBLIC_BASE_URL=http://localhost:3000
